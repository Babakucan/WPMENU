# Telegram Bot Token - @BotFather'dan al
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Sunucu portu
PORT=3005

# ngrok (Telegram URL butonları için)
USE_NGROK=true
NGROK_AUTHTOKEN=ngrok.com_dashboard_dan_al

# BASE_URL - ngrok ile otomatik güncellenir
BASE_URL=http://localhost:3005

# Admin panel şifresi (boş bırakılırsa panel şifresiz açılır)
ADMIN_PASSWORD=

# WhatsApp webhook imza doğrulaması (opsiyonel; Facebook App Secret)
# WA_APP_SECRET=

# Personel panel şifresi (opsiyonel, sadece sipariş/istatistik erişimi)
STAFF_PASSWORD=
